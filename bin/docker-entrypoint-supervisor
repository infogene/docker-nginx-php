#!/usr/bin/env bash

# Strict error handling
set -Eeuo pipefail

# Constants
readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" &>/dev/null && pwd -P)"
readonly SCRIPT_NAME="$(basename "${BASH_SOURCE[0]}")"
readonly SUPERVISOR_CONF_DIR="/etc/supervisor/conf.d"
readonly SUPERVISOR_MAIN_CONF="/etc/supervisor/supervisord.conf"

# Color codes (populated by setup_colors)
declare NOFORMAT RED GREEN ORANGE BLUE PURPLE CYAN YELLOW

# Configuration flags
declare -i ENABLE_XDEBUG=0
declare -i MODE_DEV=0
declare -i MODE_PROD=0
declare -i START_CRON=0
declare -i START_BACKEND=0
declare -i START_FRONTEND=0
declare BOOT_CMD="${APP_BOOT_CMD:-}"
declare CLI_CMD=""

# Trap cleanup on exit
trap cleanup SIGINT SIGTERM ERR EXIT

#######################################
# Cleanup function called on exit
#######################################
cleanup() {
  trap - SIGINT SIGTERM ERR EXIT
  # Gracefully stop supervisor if running
  if pgrep -x supervisord >/dev/null 2>&1; then
    supervisorctl shutdown >/dev/null 2>&1 || true
  fi
}

#######################################
# Setup terminal colors
#######################################
setup_colors() {
  if [[ -t 2 ]] && [[ -z "${NO_COLOR:-}" ]] && [[ "${TERM:-}" != "dumb" ]]; then
    NOFORMAT='\033[0m'
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    ORANGE='\033[0;33m'
    BLUE='\033[0;34m'
    PURPLE='\033[0;35m'
    CYAN='\033[0;36m'
    YELLOW='\033[1;33m'
  else
    NOFORMAT='' RED='' GREEN='' ORANGE='' BLUE='' PURPLE='' CYAN='' YELLOW=''
  fi
}

#######################################
# Print message to stderr
# Arguments:
#   Message to print
#######################################
msg() {
  echo >&2 -e "${1-}"
}

#######################################
# Print error and exit
# Arguments:
#   Error message
#   Exit code (default: 1)
#######################################
die() {
  local msg=$1
  local code=${2-1}
  msg "${RED}ERROR: ${msg}${NOFORMAT}"
  exit "$code"
}

#######################################
# Print usage information
#######################################
usage() {
  cat <<EOF
Usage: ${SCRIPT_NAME} [OPTIONS] [ARGS...]

Docker entrypoint for PHP/Node.js application with Supervisor-managed services.

OPTIONS:
  -h, --help              Show this help message and exit
  -v, --verbose           Enable verbose output (set -x)
  --no-color              Disable colored output

  Mode Options:
  --mode-dev              Run in development mode (enables xdebug)
  --mode-prod             Run in production mode (default)
  --enable-xdebug         Explicitly enable xdebug

  Service Options:
  --start-cron            Enable cron service
  --start-backend         Enable Nginx + PHP-FPM services
  --start-frontend        Enable frontend server
  --start-all             Enable all services (backend + frontend + cron)

  Execution Options:
  --boot-cmd COMMAND      Run command during bootstrap (e.g., "php bin/console cache:clear")
  --cli COMMAND           Run in CLI mode and exit (services won't start)

ARGUMENTS:
  If any arguments are provided, they will be executed directly,
  and all options will be ignored (passthrough mode).

ENVIRONMENT VARIABLES:
  APP_ENV                 Application environment (dev/prod)
  APP_BOOT_CMD            Default boot command

EXAMPLES:
  # Start backend services (nginx + php-fpm)
  ${SCRIPT_NAME} --start-backend --mode-prod

  # Start all services
  ${SCRIPT_NAME} --start-all --mode-dev

  # Run a CLI command
  ${SCRIPT_NAME} --cli "php bin/console app:command"

  # Passthrough mode (run bash)
  ${SCRIPT_NAME} bash

NOTES:
  All services are managed by Supervisor for robust process management.
  Logs are automatically directed to stdout/stderr for Docker compatibility.

EOF
  exit 0
}

#######################################
# Parse command line parameters
# Arguments:
#   All command line arguments
#######################################
parse_params() {
  local args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)
        usage
        ;;
      -v|--verbose)
        set -x
        shift
        ;;
      --no-color)
        NO_COLOR=1
        shift
        ;;
      --enable-xdebug)
        ENABLE_XDEBUG=1
        shift
        ;;
      --mode-dev)
        MODE_DEV=1
        shift
        ;;
      --mode-prod)
        MODE_PROD=1
        shift
        ;;
      --start-cron)
        START_CRON=1
        shift
        ;;
      --start-backend)
        START_BACKEND=1
        shift
        ;;
      --start-frontend)
        START_FRONTEND=1
        shift
        ;;
      --start-all)
        START_BACKEND=1
        START_FRONTEND=1
        START_CRON=1
        shift
        ;;
      --boot-cmd)
        BOOT_CMD="${2:-}"
        [[ -z "$BOOT_CMD" ]] && die "Missing value for --boot-cmd"
        shift 2
        ;;
      --cli)
        CLI_CMD="${2:-}"
        [[ -z "$CLI_CMD" ]] && die "Missing value for --cli"
        shift 2
        ;;
      -?*)
        die "Unknown option: $1"
        ;;
      *)
        args+=("$1")
        shift
        ;;
    esac
  done

  # If arguments provided, enable passthrough mode
  if [[ ${#args[@]} -gt 0 ]]; then
    exec "${args[@]}"
  fi

  # Determine mode based on flags and environment
  if [[ $MODE_DEV -eq 0 && $MODE_PROD -eq 0 ]]; then
    if [[ "${APP_ENV:-prod}" == "dev" ]]; then
      MODE_DEV=1
    else
      MODE_PROD=1
    fi
  fi

  # Mode-specific settings
  if [[ $MODE_DEV -eq 1 ]]; then
    MODE_PROD=0
    ENABLE_XDEBUG=1
  fi

  if [[ $MODE_PROD -eq 1 ]]; then
    MODE_DEV=0
  fi
}

#######################################
# Enable PHP xdebug extension
#######################################
enable_xdebug() {
  [[ $ENABLE_XDEBUG -eq 0 ]] && return 0
  [[ $(id -u) -ne 0 ]] && return 0

  if ! php -m | grep -q "xdebug"; then
    msg "${CYAN}  ↳ Enabling xdebug...${NOFORMAT}"
    docker-php-ext-enable xdebug &>/dev/null || die "Failed to enable xdebug"
  fi
}

#######################################
# Configure development mode
#######################################
setup_dev_mode() {
  [[ $MODE_DEV -eq 0 ]] && return 0

  export APP_ENV=dev
  msg "${GREEN}  ↳ Running in DEVELOPMENT MODE${NOFORMAT}"
  msg "${CYAN}    APP_ENV=${APP_ENV}${NOFORMAT}"

  # Configure git safe directory
  if command -v docker-exec-www-data &>/dev/null; then
    docker-exec-www-data git config --global --add safe.directory /application 2>/dev/null || true
  fi
}

#######################################
# Configure production mode
#######################################
setup_prod_mode() {
  [[ $MODE_PROD -eq 0 ]] && return 0

  export APP_ENV=prod
  msg "${GREEN}  ↳ Running in PRODUCTION MODE${NOFORMAT}"
  msg "${CYAN}    APP_ENV=${APP_ENV}${NOFORMAT}"
}

#######################################
# Run bootstrap command
#######################################
run_boot_command() {
  [[ -z "$BOOT_CMD" ]] && return 0

  msg "${CYAN}  ↳ Running bootstrap command...${NOFORMAT}"
  msg "${CYAN}    Command: ${BOOT_CMD}${NOFORMAT}"

  if command -v docker-exec-www-data &>/dev/null; then
    docker-exec-www-data ${BOOT_CMD} || die "Boot command failed"
  else
    eval "$BOOT_CMD" || die "Boot command failed"
  fi
}

#######################################
# Run CLI command and exit
#######################################
run_cli_mode() {
  [[ -z "$CLI_CMD" ]] && return 0

  msg "${CYAN}  ↳ Running CLI command...${NOFORMAT}"

  if command -v docker-exec-www-data &>/dev/null; then
    exec docker-exec-www-data ${CLI_CMD}
  else
    exec bash -c "$CLI_CMD"
  fi
}

#######################################
# Initialize Supervisor configuration
#######################################
init_supervisor_config() {
  msg "${CYAN}  ↳ Initializing Supervisor configuration...${NOFORMAT}"

  # Create supervisor conf directory if it doesn't exist
  mkdir -p "$SUPERVISOR_CONF_DIR"

  # Clear any existing service configurations
  rm -f "${SUPERVISOR_CONF_DIR}"/*.conf 2>/dev/null || true

  # Generate random password for supervisor (optional)
  local supervisor_user="admin"
  local supervisor_pass="${SUPERVISOR_PASSWORD:-$(openssl rand -base64 12)}"

  # Create main supervisord config if it doesn't exist
  if [[ ! -f "$SUPERVISOR_MAIN_CONF" ]]; then
    cat > "$SUPERVISOR_MAIN_CONF" <<SUPERVISORD_EOF
[unix_http_server]
file=/var/run/supervisor.sock
chmod=0700
username=${supervisor_user}
password=${supervisor_pass}

[supervisord]
nodaemon=true
logfile=/dev/null
logfile_maxbytes=0
loglevel=info
pidfile=/var/run/supervisord.pid
user=root

[rpcinterface:supervisor]
supervisor.rpcinterface_factory = supervisor.rpcinterface:make_main_rpcinterface

[supervisorctl]
serverurl=unix:///var/run/supervisor.sock
username=${supervisor_user}
password=${supervisor_pass}

[include]
files = /etc/supervisor/conf.d/*.conf
SUPERVISORD_EOF
  fi
}

#######################################
# Configure Nginx service in Supervisor
#######################################
configure_nginx_service() {
  msg "${CYAN}    ↳ Configuring Nginx service...${NOFORMAT}"

  cat > "${SUPERVISOR_CONF_DIR}/nginx.conf" <<NGINX_EOF
[program:nginx]
command=/usr/sbin/nginx -g "daemon off;"
autostart=true
autorestart=true
startretries=3
stdout_logfile=/dev/stdout
stdout_logfile_maxbytes=0
stderr_logfile=/dev/stderr
stderr_logfile_maxbytes=0
priority=10
user=www-data
NGINX_EOF
}

#######################################
# Configure PHP-FPM service in Supervisor
#######################################
configure_phpfpm_service() {
  msg "${CYAN}    ↳ Configuring PHP-FPM service...${NOFORMAT}"

  cat > "${SUPERVISOR_CONF_DIR}/php-fpm.conf" <<PHPFPM_EOF
[program:php-fpm]
command=/usr/local/sbin/php-fpm -F
autostart=true
autorestart=true
startretries=3
stdout_logfile=/dev/stdout
stdout_logfile_maxbytes=0
stderr_logfile=/dev/stderr
stderr_logfile_maxbytes=0
priority=10
user=root
PHPFPM_EOF
}

#######################################
# Configure Frontend service in Supervisor
#######################################
configure_frontend_service() {
  [[ $START_FRONTEND -eq 0 ]] && return 0

  msg "${CYAN}    ↳ Configuring Frontend service...${NOFORMAT}"

  local frontend_cmd="yarn --cwd /application/frontend ${APP_ENV:-dev}"

  cat > "${SUPERVISOR_CONF_DIR}/frontend.conf" <<FRONTEND_EOF
[program:frontend]
command=/bin/bash -c "exec ${frontend_cmd}"
autostart=true
autorestart=true
startretries=3
stdout_logfile=/dev/stdout
stdout_logfile_maxbytes=0
stderr_logfile=/dev/stderr
stderr_logfile_maxbytes=0
priority=20
user=www-data
directory=/application/frontend
environment=NODE_ENV="${APP_ENV:-development}",HOME="/home/www-data"
FRONTEND_EOF
}

#######################################
# Configure Cron service in Supervisor
#######################################
configure_cron_service() {
  [[ $START_CRON -eq 0 ]] && return 0

  msg "${CYAN}    ↳ Configuring Cron service...${NOFORMAT}"

  # Display current crontab
  if crontab -u www-data -l 2>/dev/null | grep -v '^#' | grep -v '^$'; then
    msg "${CYAN}      Active crontab entries loaded${NOFORMAT}"
  fi

  cat > "${SUPERVISOR_CONF_DIR}/cron.conf" <<CRON_EOF
[program:cron]
command=/usr/sbin/cron -f
autostart=true
autorestart=true
startretries=3
stdout_logfile=/dev/stdout
stdout_logfile_maxbytes=0
stderr_logfile=/dev/stderr
stderr_logfile_maxbytes=0
priority=5
user=root
CRON_EOF
}

#######################################
# Start services with Supervisor
#######################################
start_services() {
  local service_count=0

  msg "${GREEN}  ↳ Starting services with Supervisor...${NOFORMAT}"

  # Configure requested services
  if [[ $START_BACKEND -eq 1 ]]; then
    configure_nginx_service
    configure_phpfpm_service
    ((service_count += 2))
  fi

  if [[ $START_CRON -eq 1 ]]; then
    configure_cron_service
    ((service_count += 1))
  fi

  if [[ $START_FRONTEND -eq 1 ]]; then
    configure_frontend_service
    ((service_count += 1))
  fi

  # Check if any services were configured
  if [[ $service_count -eq 0 ]]; then
    msg "${YELLOW}⚠ No services configured. Use --help for usage information.${NOFORMAT}"
    exit 1
  fi

  msg "${GREEN}  ↳ Configured ${service_count} service(s)${NOFORMAT}"
  msg "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NOFORMAT}"
  echo ""

  # Start supervisord in foreground
  exec /usr/bin/supervisord -c "$SUPERVISOR_MAIN_CONF"
}

#######################################
# Main execution flow
#######################################
main() {
  setup_colors
  parse_params "$@"

  msg "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NOFORMAT}"
  msg "${BLUE}  Docker Entrypoint${NOFORMAT}"
  msg "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NOFORMAT}"

  # Setup phase
  enable_xdebug
  setup_dev_mode
  setup_prod_mode
  run_boot_command

  # CLI mode (exits immediately)
  run_cli_mode

  # Service mode (starts supervisor)
  init_supervisor_config
  start_services
}

# Execute main function
main "$@"