#!/usr/bin/env bash
#
# Génère un supervisord.conf à partir des arguments CLI (--supervisor-*) puis
# lance supervisord. Appelé par docker-entrypoint via l'option --start-supervisor-cli,
# mais utilisable aussi seul.
#
# --supervisor-program est RÉPÉTABLE : chaque occurrence ouvre une nouvelle
# section [program]. Toutes les autres options --supervisor-* ont une valeur par
# défaut et sont surchargeables :
#   * placées AVANT le 1er --supervisor-program -> défaut global (tous les programmes)
#   * placées APRÈS un --supervisor-program      -> surcharge CE programme uniquement
#
# Règle de mapping : --supervisor-<a>-<b> VALUE  ->  a_b=VALUE  dans [program]
#   exceptions :
#     --supervisor-program        -> command=<VALUE> (ouvre un nouveau programme)
#     --supervisor-program-name   -> nom du programme courant (défaut: app, app2, app3, ...)

set -Eeuo pipefail

readonly SCRIPT_NAME="$(basename "$0")"
# Chemin par défaut volontairement inscriptible par www-data comme par root.
readonly SUPERVISORD_CONF="${SUPERVISORD_CONF:-/tmp/supervisord.conf}"

# --- Valeurs par défaut appliquées à CHAQUE programme (surchargeables) --------
declare -A GLOBAL=(
  [autostart]="true"
  [autorestart]="true"
  [startretries]="3"
  [stopasgroup]="true"
  [killasgroup]="true"
  [user]="www-data"
  [stdout_logfile]="/dev/stdout"
  [stderr_logfile]="/dev/stderr"
  [stdout_logfile_maxbytes]="0"
  [stderr_logfile_maxbytes]="0"
)

# Ordre d'écriture des directives connues (lisibilité). Les clés inconnues
# (nouveaux paramètres) sont écrites ensuite, sans modification de code.
readonly KEY_ORDER=(
  command autostart autorestart startsecs startretries
  stopsignal stopwaitsecs stopasgroup killasgroup
  user directory environment numprocs priority
  stdout_logfile stdout_logfile_maxbytes
  stderr_logfile stderr_logfile_maxbytes
)

# Programmes accumulés
declare -a PROG_CMD=()    # commande par programme
declare -a PROG_NAME=()   # nom par programme ("" = défaut)
declare -i CUR=-1         # index du programme courant (-1 = aucun encore)

die() {
  echo >&2 "ERREUR: $1"
  exit "${2:-1}"
}

usage() {
  cat <<EOF
Usage: ${SCRIPT_NAME} --supervisor-program "<cmd>" [--supervisor-program "<cmd2>" ...] [OPTIONS...]

Génère dynamiquement un supervisord.conf (1 section [program] par --supervisor-program)
puis lance supervisord.

Obligatoire (répétable):
  --supervisor-program "<cmd>"     Ouvre une nouvelle section [program]

Optionnel — défauts appliqués à chaque programme (surchargeables):
  --supervisor-program-name NAME   Nom du programme courant  (défaut: app, app2, ...)
  --supervisor-autostart BOOL      autostart                 (défaut: true)
  --supervisor-autorestart BOOL    autorestart               (défaut: true)
  --supervisor-startretries N      startretries              (défaut: 3)
  --supervisor-stopasgroup BOOL    stopasgroup               (défaut: true)
  --supervisor-killasgroup BOOL    killasgroup               (défaut: true)
  --supervisor-user USER           user                      (défaut: www-data)
  --supervisor-stdout-logfile PATH stdout_logfile            (défaut: /dev/stdout)
  --supervisor-stderr-logfile PATH stderr_logfile            (défaut: /dev/stderr)

Portée des options:
  * AVANT le 1er --supervisor-program -> défaut global (tous les programmes)
  * APRÈS un --supervisor-program     -> surcharge CE programme uniquement

Extensible : toute option --supervisor-<a>-<b> VALUE devient « a_b=VALUE ».
Exemple : --supervisor-stop-signal TERM -> stop_signal=TERM

  -h, --help                       Affiche cette aide
EOF
  exit 0
}

# Ouvre un nouveau programme initialisé avec les défauts globaux courants.
new_program() {
  CUR=$((CUR + 1))
  PROG_CMD[$CUR]="$1"
  PROG_NAME[$CUR]=""
  declare -gA "PROGDIR_${CUR}"
  local -n _dir="PROGDIR_${CUR}"
  local k
  for k in "${!GLOBAL[@]}"; do
    _dir["$k"]="${GLOBAL[$k]}"
  done
}

# Applique une directive : au programme courant, ou aux défauts globaux si aucun
# programme n'a encore été ouvert.
set_directive() {
  local key="$1" val="$2"
  if [[ $CUR -lt 0 ]]; then
    GLOBAL["$key"]="$val"
  else
    local -n _dir="PROGDIR_${CUR}"
    _dir["$key"]="$val"
  fi
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)
        usage
        ;;
      --supervisor-program)
        [[ $# -ge 2 ]] || die "L'option $1 requiert une valeur"
        new_program "$2"
        shift 2
        ;;
      --supervisor-program-name)
        [[ $# -ge 2 ]] || die "L'option $1 requiert une valeur"
        [[ $CUR -ge 0 ]] || die "$1 doit suivre un --supervisor-program"
        [[ "$2" =~ ^[A-Za-z0-9_.-]+$ ]] || die "Nom de programme invalide: $2"
        PROG_NAME[$CUR]="$2"
        shift 2
        ;;
      --supervisor-*)
        [[ $# -ge 2 ]] || die "L'option $1 requiert une valeur"
        local key="${1#--supervisor-}"   # ex: stdout-logfile
        key="${key//-/_}"                # ex: stdout_logfile
        set_directive "$key" "$2"
        shift 2
        ;;
      *)
        die "Argument inconnu: $1 (voir --help)"
        ;;
    esac
  done

  [[ $CUR -ge 0 ]] || die "au moins un --supervisor-program est requis (voir --help)"
}

# Écrit la section [program] d'index $1. Nameref frais à chaque appel.
emit_program() {
  local idx="$1"
  local name="${PROG_NAME[$idx]}"
  if [[ -z "$name" ]]; then
    [[ $idx -eq 0 ]] && name="app" || name="app$((idx + 1))"
  fi

  local -n _dir="PROGDIR_${idx}"
  echo ""
  echo "[program:${name}]"
  echo "command=${PROG_CMD[$idx]}"

  # Directives connues, dans l'ordre (on saute "command", déjà écrite)
  local emitted=" command "
  local key
  for key in "${KEY_ORDER[@]}"; do
    [[ "$key" == "command" ]] && continue
    if [[ -n "${_dir[$key]+set}" ]]; then
      echo "${key}=${_dir[$key]}"
      emitted+="$key "
    fi
  done

  # Directives supplémentaires non listées dans KEY_ORDER (extensibilité)
  for key in "${!_dir[@]}"; do
    [[ "$emitted" == *" $key "* ]] && continue
    echo "${key}=${_dir[$key]}"
  done
}

generate_conf() {
  mkdir -p "$(dirname "$SUPERVISORD_CONF")"
  {
    echo "[supervisord]"
    echo "nodaemon=true"
    local i
    for ((i = 0; i <= CUR; i++)); do
      emit_program "$i"
    done
  } > "$SUPERVISORD_CONF"
}

main() {
  parse_args "$@"
  generate_conf

  echo ">> Configuration Supervisor générée (${SUPERVISORD_CONF}) :"
  echo "----------------------------------------"
  cat "$SUPERVISORD_CONF"
  echo "----------------------------------------"

  exec supervisord -c "$SUPERVISORD_CONF"
}

main "$@"
