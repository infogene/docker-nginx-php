#!/usr/bin/env bash

# Strict error handling
set -Eeuo pipefail

# Constants
readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" &>/dev/null && pwd -P)"
readonly SCRIPT_NAME="$(basename "${BASH_SOURCE[0]}")"

# Color codes (populated by setup_colors)
declare NOFORMAT RED GREEN ORANGE BLUE PURPLE CYAN YELLOW

# Configuration flags
declare -i ENABLE_XDEBUG=0
declare -i MODE_DEV=0
declare -i MODE_PROD=0
declare -i START_CRON=0
declare -i START_BACKEND=0
declare -i START_FRONTEND=0
declare BOOT_CMD="${APP_BOOT_CMD:-}"
declare CLI_CMD=""

# Trap cleanup on exit
trap cleanup SIGINT SIGTERM ERR EXIT

#######################################
# Cleanup function called on exit
#######################################
cleanup() {
  trap - SIGINT SIGTERM ERR EXIT
  # Add cleanup logic here if needed
}

#######################################
# Setup terminal colors
#######################################
setup_colors() {
  if [[ -t 2 ]] && [[ -z "${NO_COLOR:-}" ]] && [[ "${TERM:-}" != "dumb" ]]; then
    NOFORMAT='\033[0m'
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    ORANGE='\033[0;33m'
    BLUE='\033[0;34m'
    PURPLE='\033[0;35m'
    CYAN='\033[0;36m'
    YELLOW='\033[1;33m'
  else
    NOFORMAT='' RED='' GREEN='' ORANGE='' BLUE='' PURPLE='' CYAN='' YELLOW=''
  fi
}

#######################################
# Print message to stderr
# Arguments:
#   Message to print
#######################################
msg() {
  echo >&2 -e "${1-}"
}

#######################################
# Print error and exit
# Arguments:
#   Error message
#   Exit code (default: 1)
#######################################
die() {
  local msg=$1
  local code=${2-1}
  msg "${RED}ERROR: ${msg}${NOFORMAT}"
  exit "$code"
}

#######################################
# Print usage information
#######################################
usage() {
  cat <<EOF
Usage: ${SCRIPT_NAME} [OPTIONS] [ARGS...]

Docker entrypoint for PHP/Node.js application with multiple runtime modes.

OPTIONS:
  -h, --help              Show this help message and exit
  -v, --verbose           Enable verbose output (set -x)
  --no-color              Disable colored output

  Mode Options:
  --mode-dev              Run in development mode (enables xdebug)
  --mode-prod             Run in production mode (default)
  --enable-xdebug         Explicitly enable xdebug

  Service Options:
  --start-cron            Start cron service only
  --start-backend         Start Nginx + PHP-FPM only
  --start-frontend        Start frontend server only
  --start-all             Start both backend and frontend services

  Execution Options:
  --boot-cmd COMMAND      Run command during bootstrap (e.g., "php bin/console cache:clear")
  --cli COMMAND           Run in CLI mode and exit (services won't start)

ARGUMENTS:
  If any arguments are provided, they will be executed directly,
  and all options will be ignored (passthrough mode).

ENVIRONMENT VARIABLES:
  APP_ENV                 Application environment (dev/prod)
  APP_BOOT_CMD            Default boot command

EXAMPLES:
  # Start in production mode with backend only
  ${SCRIPT_NAME} --start-backend --mode-prod

  # Start in dev mode with all services
  ${SCRIPT_NAME} --start-all --mode-dev

  # Run a CLI command
  ${SCRIPT_NAME} --cli "php bin/console app:command"

  # Passthrough mode (run bash)
  ${SCRIPT_NAME} bash

EOF
  exit 0
}

#######################################
# Parse command line parameters
# Arguments:
#   All command line arguments
#######################################
parse_params() {
  local args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)
        usage
        ;;
      -v|--verbose)
        set -x
        shift
        ;;
      --no-color)
        NO_COLOR=1
        shift
        ;;
      --enable-xdebug)
        ENABLE_XDEBUG=1
        shift
        ;;
      --mode-dev)
        MODE_DEV=1
        shift
        ;;
      --mode-prod)
        MODE_PROD=1
        shift
        ;;
      --start-cron)
        START_CRON=1
        shift
        ;;
      --start-backend)
        START_BACKEND=1
        shift
        ;;
      --start-frontend)
        START_FRONTEND=1
        shift
        ;;
      --start-all)
        START_BACKEND=1
        START_FRONTEND=1
        shift
        ;;
      --boot-cmd)
        BOOT_CMD="${2:-}"
        [[ -z "$BOOT_CMD" ]] && die "Missing value for --boot-cmd"
        shift 2
        ;;
      --cli)
        CLI_CMD="${2:-}"
        [[ -z "$CLI_CMD" ]] && die "Missing value for --cli"
        shift 2
        ;;
      -?*)
        die "Unknown option: $1"
        ;;
      *)
        args+=("$1")
        shift
        ;;
    esac
  done

  # If arguments provided, enable passthrough mode
  if [[ ${#args[@]} -gt 0 ]]; then
    exec "${args[@]}"
  fi

  # Determine mode based on flags and environment
  if [[ $MODE_DEV -eq 0 && $MODE_PROD -eq 0 ]]; then
    if [[ "${APP_ENV:-prod}" == "dev" ]]; then
      MODE_DEV=1
    else
      MODE_PROD=1
    fi
  fi

  # Mode-specific settings
  if [[ $MODE_DEV -eq 1 ]]; then
    MODE_PROD=0
    ENABLE_XDEBUG=1
  fi

  if [[ $MODE_PROD -eq 1 ]]; then
    MODE_DEV=0
  fi
}

#######################################
# Enable PHP xdebug extension
#######################################
enable_xdebug() {
  [[ $ENABLE_XDEBUG -eq 0 ]] && return 0
  [[ $(id -u) -ne 0 ]] && return 0

  if ! php -m | grep -q "xdebug"; then
    msg "${CYAN}  ↳ Enabling xdebug...${NOFORMAT}"
    docker-php-ext-enable xdebug &>/dev/null || die "Failed to enable xdebug"
  fi
}

#######################################
# Configure development mode
#######################################
setup_dev_mode() {
  [[ $MODE_DEV -eq 0 ]] && return 0

  export APP_ENV=dev
  msg "${GREEN}  ↳ Running in DEVELOPMENT MODE${NOFORMAT}"
  msg "${CYAN}    APP_ENV=${APP_ENV}${NOFORMAT}"

  # Configure git safe directory
  if command -v docker-exec-www-data &>/dev/null; then
    docker-exec-www-data git config --global --add safe.directory /application 2>/dev/null || true
  fi
}

#######################################
# Configure production mode
#######################################
setup_prod_mode() {
  [[ $MODE_PROD -eq 0 ]] && return 0

  export APP_ENV=prod
  msg "${GREEN}  ↳ Running in PRODUCTION MODE${NOFORMAT}"
  msg "${CYAN}    APP_ENV=${APP_ENV}${NOFORMAT}"
}

#######################################
# Run bootstrap command
#######################################
run_boot_command() {
  [[ -z "$BOOT_CMD" ]] && return 0

  msg "${CYAN}  ↳ Running bootstrap command...${NOFORMAT}"
  msg "${CYAN}    Command: ${BOOT_CMD}${NOFORMAT}"

  if command -v docker-exec-www-data &>/dev/null; then
    docker-exec-www-data ${BOOT_CMD} || die "Boot command failed"
  else
    eval "$BOOT_CMD" || die "Boot command failed"
  fi
}

#######################################
# Run CLI command and exit
#######################################
run_cli_mode() {
  [[ -z "$CLI_CMD" ]] && return 0

  msg "${CYAN}  ↳ Running CLI command...${NOFORMAT}"

  if command -v docker-exec-www-data &>/dev/null; then
    exec docker-exec-www-data ${CLI_CMD}
  else
    exec bash -c "$CLI_CMD"
  fi
}

#######################################
# Start cron service
#######################################
start_cron() {
  [[ $START_CRON -eq 0 ]] && return 0

  msg "${GREEN}  ↳ Starting cron service...${NOFORMAT}"

  # Display crontab
  if crontab -u www-data -l 2>/dev/null; then
    echo ""
  fi

  exec /usr/sbin/crond -f
}

#######################################
# Start frontend service
#######################################
start_frontend() {
  [[ $START_FRONTEND -eq 0 ]] && return 0

  msg "${GREEN}  ↳ Starting frontend server...${NOFORMAT}"

  if command -v docker-exec-www-data &>/dev/null; then
    if [[ $START_BACKEND -eq 1 ]]; then
      # Start in background if backend also starting
      docker-exec-www-data yarn --cwd frontend "${APP_ENV:-dev}" &
    else
      # Start in foreground if only frontend
      exec docker-exec-www-data yarn --cwd frontend "${APP_ENV:-dev}"
    fi
  else
    die "docker-exec-www-data command not found"
  fi
}

#######################################
# Start backend service (Nginx + PHP-FPM)
#######################################
start_backend() {
  [[ $START_BACKEND -eq 0 ]] && return 0

  msg "${GREEN}  ↳ Starting Nginx + PHP-FPM...${NOFORMAT}"
  echo ""

  # Start Nginx in background
  nginx -g 'daemon off;' &

  # Start PHP-FPM in foreground
  exec php-fpm -F
}

#######################################
# Main execution flow
#######################################
main() {
  setup_colors
  parse_params "$@"

  msg "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NOFORMAT}"
  msg "${BLUE}  Starting entrypoint...${NOFORMAT}"
  msg "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NOFORMAT}"

  # Setup phase
  enable_xdebug
  setup_dev_mode
  setup_prod_mode
  run_boot_command

  # Execution phase
  run_cli_mode    # Exits if CLI mode
  start_cron      # Exits if cron mode
  start_frontend  # May run in background
  start_backend   # Exits with exec

  # If we reach here and nothing started, show warning
  msg "${YELLOW}⚠ No service started. Use --help for usage information.${NOFORMAT}"
  exit 1
}

# Execute main function
main "$@"